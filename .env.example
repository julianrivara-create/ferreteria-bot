# ==========================================
# SYSTEM CONFIGURATION
# ==========================================

# Server
HOST=0.0.0.0
PORT=8080
DEBUG=false
ENVIRONMENT=development

# ==========================================
# STORE CONFIGURATION (MULTI-PRODUCT)
# ==========================================

# Store Identity
STORE_NAME="Ferretería"
STORE_TYPE="ferretería"
STORE_COUNTRY="Argentina"

# Product Categories (comma-separated)
# Leave empty to auto-detect from catalog.csv (recomendado)
# Ejemplos ferretería:
#   - "Llaves,Bocallaves y Dados,Destornilladores,Pinzas y Alicates"
#   - "Bulonería,Tarugos y Tacos,Herramientas Electricas"
PRODUCT_CATEGORIES=""

# Cross-sell Configuration
# Categories eligible for cross-selling (comma-separated)
# Leave empty to enable for all categories
# Example: "Llaves,Mechas,Tornillos"
CROSSSELL_CATEGORIES=""

# Default Category (for backward compatibility, leave empty for no default)
DEFAULT_CATEGORY=""

# Business Rules
ENABLE_UPSELLING=true
ENABLE_CROSSSELLING=true
ENABLE_BUNDLES=true

# ==========================================
# AI CONFIGURATION
# ==========================================

# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4

# Gemini (Alternative)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-pro

# ==========================================
# WHATSAPP INTEGRATION
# ==========================================
WHATSAPP_PROVIDER=mock
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886
META_ACCESS_TOKEN=your_meta_access_token
META_PHONE_NUMBER_ID=your_phone_number_id
META_VERIFY_TOKEN=my_verify_token

# ==========================================
# INSTAGRAM INTEGRATION
# ==========================================
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_VERIFY_TOKEN=instagram_verify_token_123

# ==========================================
# SLACK INTEGRATION
# ==========================================
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Slack Advanced Features
SLACK_ADMIN_CHANNEL=C12345678
SLACK_REPORTS_CHANNEL=C12345678
SLACK_APPROVAL_CHANNEL=C12345678
SLACK_ADMIN_USERS=U12345,U67890

# Handoff Rules
SLACK_ENABLE_HANDOFF=true
HANDOFF_AMOUNT_THRESHOLD=5000
HANDOFF_SENTIMENT_THRESHOLD=-0.5

# Multi-Channel Alerts
SLACK_ALERT_EMAIL_ENABLED=false
SLACK_ALERT_EMAIL=admin@example.com
SLACK_ALERT_WHATSAPP_ENABLED=false
SLACK_ALERT_WHATSAPP=+5491122334455

# Approval Rules
REQUIRE_APPROVAL_DISCOUNT_OVER=10
REQUIRE_APPROVAL_HOLD_OVER=60
AUTO_APPROVE_DISCOUNT_UNDER=5
APPROVAL_TIMEOUT_MINUTES=5

# Automated Reports
SLACK_ENABLE_AUTO_REPORTS=true
SLACK_DAILY_REPORT_TIME=09:00
SLACK_WEEKLY_REPORT_DAY=monday

# ==========================================
# CRM INTEGRATION
# ==========================================
CRM_PROVIDER=salesforce  # or hubspot, or leave empty to disable
SALESFORCE_API_KEY=your_salesforce_api_key
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
HUBSPOT_API_KEY=your_hubspot_api_key

# ==========================================
# ANALYTICS & A/B TESTING
# ==========================================
ANALYTICS_CHART_STORAGE=slack_files  # or s3
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key

AB_TESTING_ENABLED=true
AB_TEST_ASSIGNMENT_METHOD=hash  # or random

# ==========================================
# SENTIMENT ANALYSIS
# ==========================================
SENTIMENT_PROVIDER=textblob  # or openai, vader
SENTIMENT_ALERT_THRESHOLD=-0.3

# ==========================================
# EMAIL CONFIGURATION
# ==========================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ==========================================
# PAYMENT CONFIGURATION
# ==========================================

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=your_mp_token
MERCADOPAGO_PUBLIC_KEY=your_mp_public_key
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret

# ==========================================
# GOOGLE SHEETS INTEGRATION
# ==========================================

GOOGLE_SHEETS_CREDENTIALS=path/to/credentials.json
GOOGLE_SHEET_ID=your_sheet_id

# ==========================================
# REDIS CACHE
# ==========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
ENABLE_CACHE=true

# ==========================================
# DATABASE
# ==========================================

# DATABASE_PATH está deprecado en el runtime final.
DATABASE_URL=sqlite:///data/store.db

# ==========================================
# BUSINESS LOGIC
# ==========================================

HOLD_MINUTES=30
LITE_MODE=false

# ==========================================
# FEATURES
# ==========================================

ENABLE_FRAUD_DETECTION=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_AB_TESTING=false

# ==========================================
# MONITORING
# ==========================================

LOG_LEVEL=INFO
LOG_DIR=logs
SENTRY_DSN=your_sentry_dsn

# ==========================================
# ADMIN DASHBOARD
# ==========================================

ADMIN_USERNAME=admin
ADMIN_PASSWORD=<required-set-this>
FERRETERIA_WHATSAPP_PHONE_NUMBER_ID=<from-meta>
FERRETERIA_ADMIN_PHONE_ID=<internal>
SECRET_KEY=change_this_to_random_string_in_production
