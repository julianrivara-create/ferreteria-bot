# Configuration for Hybrid mode (Best of both worlds)
# Tries Ollama first (free, fast), falls back to OpenAI if needed

LLM_CLIENT=auto

# Ollama (primary - free, local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=glm4:9b

# OpenAI (fallback - paid, best quality)
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4

# Database
DATABASE_PATH=data/iphone_store.db
CATALOG_CSV=data/products.csv
LOG_FILE=data/sales_bot.log

# This configuration gives you:
# - 80%+ queries handled by Ollama (FREE)
# - 20% complex queries to GPT-4 (when needed)
# - Automatic failover if Ollama is down
# Result: ~80% cost savings!
