# LLM Backend Configuration

## Default (Auto-detect)
LLM_BACKEND=auto  # Will try: Ollama → LM Studio → OpenAI

## Ollama (Recommended - Free, Local)
#LLM_BACKEND=ollama
#OLLAMA_HOST=http://localhost:11434
#OLLAMA_MODEL=glm4:9b  # or: llama3.3:70b, mistral:7b, qwen2.5:32b

## LM Studio (Alternative - Free, Local)
#LLM_BACKEND=lmstudio
#LMSTUDIO_HOST=http://localhost:1234
#LMSTUDIO_MODEL=local-model

## OpenAI (Paid, Cloud)
#LLM_BACKEND=openai
#OPENAI_API_KEY=sk-your-key-here
#OPENAI_MODEL=gpt-4

## Other existing settings...
DATABASE_PATH=data/iphone_store.db
CATALOG_CSV=data/products.csv
LOG_FILE=data/sales_bot.log
